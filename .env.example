# Text RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FAISS_INDEX_PATH=data/parsed/faiss.index

# Vertex AI (Gemini on GCP) — required for generation
GCP_PROJECT_ID=gd-gcp-internship-ds
GCP_LOCATION=us-central1
# Vertex model resource id, e.g. gemini-2.0-flash-001, gemini-1.5-flash-002
GEMINI_MODEL=gemini-2.0-flash-001

# Service account JSON — pick ONE approach:
# A) Standard (recommended): absolute or relative path to the key file
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
# B) Directory + filename (your layout): key at {DIR}/{GCP_KEY_FILENAME}
# GOOGLE_APPLICATION_CREDENTIALS_DIR=./secrets
# GCP_KEY_FILENAME=gcp-key.json
# C) Explicit override name
# GCP_SERVICE_ACCOUNT_KEY_PATH=./gcp-key.json

# Optional observability
# Optional Langfuse tracing (leave empty if not using)
LANGFUSE_PUBLIC_KEY="pk-lf-0a32151b-bc3d-4fb9-ac99-2cf510b2f95f"
LANGFUSE_SECRET_KEY="sk-lf-a8967367-851f-4f4b-bd83-6e185e96f6bf"
LANGFUSE_HOST="https://hipaa.cloud.langfuse.com"

# Phase 2 evaluation
EVAL_DATASET_PATH=data/eval/phase2_eval_dataset.jsonl
EVAL_OUTPUT_DIR=data/eval/reports
PHASE2_EVAL_SOURCE_PDF="/Users/ssingodia/Desktop/RAG/RAG_evaluation_dataset - convertcsv (2).pdf"

# Phase 3 retrieval
ENABLE_HYBRID=true
ENABLE_RERANK=true
HYBRID_ALPHA=0.7
DENSE_TOP_K=20
SPARSE_TOP_K=20
HYBRID_TOP_N=20
RERANK_TOP_K=5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SPARSE_INDEX_PATH=data/parsed/bm25_corpus.json

# Phase 4 semantic cache + multi-hop (keep cache off for eval comparability)
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ENTRIES=500
SEMANTIC_CACHE_PATH=data/cache/semantic_cache
ENABLE_MULTI_HOP=true
# Optional: LLM rewrites the query before embedding; merges hits from raw + refined (extra latency/cost)
ENABLE_QUERY_REFINEMENT=true
MULTI_HOP_MODE=heuristic
MULTI_HOP_MERGED_TOP_K=5

# Phase 5 tables + images (optional camelot-py[cv] for lattice tables; pdfplumber is default)
ENABLE_TABLE_EXTRACTION=true
ENABLE_IMAGE_CAPTIONS=true
# Rasterize PDF pages or "Figure N" regions (PyMuPDF pixmap); indexes like embedded images
ENABLE_IMAGE_PAGE_RENDERS=true
IMAGE_PAGE_RENDER_DPI=120
# figures = crop around Figure captions (good for vector diagrams); full_pages = every page
IMAGE_PAGE_RENDER_STRATEGY=figures

# Phase 6: CLIP-class visual FAISS (separate from text index; requires image chunks + assets)
ENABLE_VISUAL_RETRIEVAL=true
VISUAL_FAISS_INDEX_PATH=data/parsed/faiss.index.visual
VISUAL_EMBEDDING_MODEL=clip-ViT-B-32
VISUAL_TOP_K=20
VISUAL_FUSION_LAMBDA=0.65
# Empty = auto (MPS on Apple Silicon, else CUDA, else CPU). Override: mps | cuda | cpu
VISUAL_DEVICE=
VISUAL_BATCH_SIZE=8
VISUAL_FOR_IMAGE_INTENT_ONLY=true

# ColPali-style late interaction (full-page rasters + MaxSim; GPU recommended; large downloads)
ENABLE_COLPALI_INDEX=true
ENABLE_COLPALI_RETRIEVAL=true
COLPALI_MODEL_ID=vidore/colpali-v1.2
COLPALI_INDEX_DIR=data/parsed/colpali
COLPALI_PAGE_DPI=150
# 0 = all pages when indexing (slow / large)
COLPALI_MAX_INDEX_PAGES=0
COLPALI_TOP_K=3
# Empty = auto: MPS (Apple GPU) if available, else CUDA, else CPU. Override: mps | cuda | cpu
COLPALI_DEVICE=
COLPALI_MAX_IMAGES_FOR_LLM=4

ENABLE_MODALITY_ROUTER=true
ROUTER_USE_LLM=false
TABLE_MAX_ROWS_PER_CHUNK=20
IMAGE_CAPTION_MAX_SIDE=1024
ASSETS_DIR=data/parsed/assets
# pdfplumber | camelot
TABLE_EXTRACTOR=pdfplumber

